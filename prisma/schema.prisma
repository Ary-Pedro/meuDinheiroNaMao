generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  CHECKING
  SAVINGS
  CASH
  CREDIT
  INVESTMENT
  OTHER
}

enum CategoryKind {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionSource {
  MANUAL
  IMPORT
  CLIENT_SERVICE
}

enum TransactionStatus {
  CONFIRMED
  PENDING_REVIEW
  ARCHIVED
}

enum TransferDirection {
  OUT
  IN
}

enum ImportSourceType {
  FILE
  MANUAL_UPLOAD
  CLIENT_SERVICE
}

enum ImportBatchStatus {
  RECEIVED
  PROCESSING
  REVIEW_REQUIRED
  COMPLETED
  FAILED
}

enum ImportedEntryStatus {
  PENDING
  MATCHED
  REVIEW_REQUIRED
  IMPORTED
  DISCARDED
}

enum ReviewItemKind {
  IMPORTED_ENTRY
  TRANSACTION
  INVESTMENT_OPERATION
}

enum ReviewItemStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum AssetType {
  STOCK
  ETF
  FII
  BOND
  CRYPTO
  CASH_EQUIVALENT
  OTHER
}

enum InvestmentOperationType {
  BUY
  SELL
  DIVIDEND
  TRANSFER_IN
  TRANSFER_OUT
}

enum SimulationBaseContext {
  FINANCE
  INVESTMENT
  MIXED
}

enum SimulationScenarioStatus {
  DRAFT
  CALCULATED
  ARCHIVED
}

enum SimulationValueType {
  STRING
  NUMBER
  BOOLEAN
  DATE
  JSON
}

enum AccountInvestmentType {
  CAIXINHA
  CDB
  FUND
  STOCK
  CRYPTO
  CASH_EQUIVALENT
  OTHER
}

enum AccountInvestmentScopeMode {
  TOTAL
  INCOME_ONLY
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  name                 String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  financialAccounts    FinancialAccount[]
  categories           Category[]
  transactions         Transaction[]
  importBatches        ImportBatch[]
  importedEntries      ImportedEntry[]
  reviewItems          ReviewItem[]
  transferGroups       TransferGroup[]
  assets               Asset[]
  investmentOperations InvestmentOperation[]
  investmentPositions  InvestmentPosition[]
  portfolioSnapshots   PortfolioSnapshot[]
  accountInvestments   AccountInvestment[]
  simulationScenarios  SimulationScenario[]
}

model FinancialAccount {
  id             String                @id @default(cuid())
  userId         String
  name           String
  type           AccountType
  institution    String?
  currency       String                @default("BRL")
  initialBalance Decimal               @db.Decimal(18, 2)
  isArchived     Boolean               @default(false)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  investmentOps  InvestmentOperation[]
  sourceTransferGroups TransferGroup[] @relation("TransferSourceAccount")
  destinationTransferGroups TransferGroup[] @relation("TransferDestinationAccount")
  accountInvestments AccountInvestment[]

  @@index([userId])
  @@index([userId, type])
  @@unique([userId, name])
}

model Category {
  id            String         @id @default(cuid())
  userId        String
  name          String
  kind          CategoryKind
  color         String?
  icon          String?
  isSystem      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subcategories Subcategory[]
  transactions  Transaction[]
  importedEntries ImportedEntry[]

  @@index([userId])
  @@index([userId, kind])
  @@unique([userId, kind, name])
}

model Subcategory {
  id           String         @id @default(cuid())
  categoryId   String
  name         String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  category     Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([categoryId])
  @@unique([categoryId, name])
}

model Transaction {
  id            String            @id @default(cuid())
  userId        String
  accountId     String
  categoryId    String?
  subcategoryId String?
  type          TransactionType
  amount        Decimal           @db.Decimal(18, 2)
  amountNative  Decimal           @default(0) @db.Decimal(18, 2)
  currency      String            @default("BRL")
  amountBrlSnapshot Decimal       @default(0) @db.Decimal(18, 2)
  fxRateApplied Decimal?          @db.Decimal(18, 8)
  fxReferenceAt DateTime?
  transferGroupId String?
  transferDirection TransferDirection?
  description   String?
  occurredAt    DateTime
  source        TransactionSource @default(MANUAL)
  status        TransactionStatus @default(CONFIRMED)
  externalRef   String?
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  account       FinancialAccount  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category      Category?         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subcategory   Subcategory?      @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  transferGroup TransferGroup?    @relation(fields: [transferGroupId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, occurredAt])
  @@index([accountId, occurredAt])
  @@index([categoryId, occurredAt])
  @@index([status])
  @@index([source])
  @@index([transferGroupId])
}

model TransferGroup {
  id                         String            @id @default(cuid())
  userId                     String
  sourceAccountId            String
  destinationAccountId       String
  sourceAmountNative         Decimal           @db.Decimal(18, 2)
  destinationAmountNative    Decimal           @db.Decimal(18, 2)
  sourceCurrency             String
  destinationCurrency        String
  sourceAmountBrlSnapshot    Decimal           @db.Decimal(18, 2)
  destinationAmountBrlSnapshot Decimal         @db.Decimal(18, 2)
  fxRateApplied              Decimal?          @db.Decimal(18, 8)
  fxReferenceAt              DateTime?
  occurredAt                 DateTime
  description                String?
  notes                      String?
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt

  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceAccount      FinancialAccount @relation("TransferSourceAccount", fields: [sourceAccountId], references: [id], onDelete: Restrict)
  destinationAccount FinancialAccount @relation("TransferDestinationAccount", fields: [destinationAccountId], references: [id], onDelete: Restrict)
  transactions       Transaction[]

  @@index([userId, occurredAt])
  @@index([sourceAccountId, occurredAt])
  @@index([destinationAccountId, occurredAt])
}

model ImportBatch {
  id         String            @id @default(cuid())
  userId     String
  sourceType ImportSourceType
  fileName   String?
  status     ImportBatchStatus @default(RECEIVED)
  startedAt  DateTime          @default(now())
  finishedAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries    ImportedEntry[]

  @@index([userId])
  @@index([userId, status])
}

model ImportedEntry {
  id                   String              @id @default(cuid())
  batchId              String
  userId               String
  rawDescription       String?
  rawAmount            Decimal             @db.Decimal(18, 2)
  rawOccurredAt        DateTime?
  rawPayload           Json
  suggestedCategoryId  String?
  matchedTransactionId String?
  status               ImportedEntryStatus @default(PENDING)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  batch                ImportBatch         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  suggestedCategory    Category?           @relation(fields: [suggestedCategoryId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@index([userId, status])
}

model ReviewItem {
  id          String           @id @default(cuid())
  userId      String
  kind        ReviewItemKind
  referenceId String
  status      ReviewItemStatus @default(OPEN)
  reason      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([kind, referenceId])
}

model Asset {
  id           String                @id @default(cuid())
  userId       String
  tickerOrName String
  assetType    AssetType
  currency     String                @default("BRL")
  broker       String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  operations   InvestmentOperation[]
  positions    InvestmentPosition[]

  @@index([userId, assetType])
  @@unique([userId, tickerOrName])
}

model InvestmentOperation {
  id          String                  @id @default(cuid())
  userId      String
  assetId     String
  accountId   String?
  type        InvestmentOperationType
  quantity    Decimal                 @db.Decimal(18, 8)
  unitPrice   Decimal                 @db.Decimal(18, 8)
  totalAmount Decimal                 @db.Decimal(18, 2)
  fees        Decimal                 @default(0) @db.Decimal(18, 2)
  occurredAt  DateTime
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset       Asset                   @relation(fields: [assetId], references: [id], onDelete: Restrict)
  account     FinancialAccount?       @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
  @@index([assetId, occurredAt])
}

model InvestmentPosition {
  id           String    @id @default(cuid())
  userId       String
  assetId      String
  quantity     Decimal   @db.Decimal(18, 8)
  averagePrice Decimal   @db.Decimal(18, 8)
  currentValue Decimal?  @db.Decimal(18, 2)
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset        Asset     @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@unique([userId, assetId])
}

model PortfolioSnapshot {
  id                String   @id @default(cuid())
  userId            String
  referenceDate     DateTime
  totalInvested     Decimal  @db.Decimal(18, 2)
  totalCurrentValue Decimal  @db.Decimal(18, 2)
  totalProfitLoss   Decimal  @db.Decimal(18, 2)
  createdAt         DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, referenceDate])
  @@unique([userId, referenceDate])
}

model AccountInvestment {
  id            String                     @id @default(cuid())
  userId        String
  accountId     String
  name          String
  investmentType AccountInvestmentType    @default(OTHER)
  principalAmount Decimal                 @db.Decimal(18, 2)
  currentValue  Decimal                   @db.Decimal(18, 2)
  incomeAmount  Decimal                   @db.Decimal(18, 2)
  scopeMode     AccountInvestmentScopeMode @default(TOTAL)
  startedAt     DateTime
  notes         String?
  isArchived    Boolean                   @default(false)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  account       FinancialAccount  @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([userId, startedAt])
  @@index([accountId, startedAt])
}

model SimulationScenario {
  id          String                   @id @default(cuid())
  userId      String
  name        String
  baseContext SimulationBaseContext
  status      SimulationScenarioStatus @default(DRAFT)
  description String?
  targetAmount Decimal?                @db.Decimal(18, 2)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  user        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  inputs      SimulationInput[]
  results     SimulationResult[]
  participants SimulationParticipant[]
  costs       SimulationCost[]

  @@index([userId, status])
  @@unique([userId, name])
}

model SimulationInput {
  id         String              @id @default(cuid())
  scenarioId String
  key        String
  value      String
  valueType  SimulationValueType
  createdAt  DateTime            @default(now())

  scenario   SimulationScenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
  @@unique([scenarioId, key])
}

model SimulationResult {
  id         String              @id @default(cuid())
  scenarioId String
  metric     String
  value      Decimal             @db.Decimal(18, 4)
  generatedAt DateTime           @default(now())

  scenario   SimulationScenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
  @@index([scenarioId, generatedAt])
}

model SimulationParticipant {
  id                   String              @id @default(cuid())
  scenarioId           String
  name                 String
  expectedContribution Decimal             @default(0) @db.Decimal(18, 2)
  actualContribution   Decimal             @default(0) @db.Decimal(18, 2)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  scenario             SimulationScenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
}

model SimulationCost {
  id         String              @id @default(cuid())
  scenarioId String
  name       String
  amount     Decimal             @db.Decimal(18, 2)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  scenario   SimulationScenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
}
